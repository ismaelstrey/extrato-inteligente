generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN_SAAS
  CLIENT_ADMIN
  USER
}

enum TransactionType {
  ENTRADA
  SAIDA
}

enum TransactionCategory {
  PIX
  VENDAS
  RENDIMENTO
  TARIFA
  JUROS
  IMPOSTOS
  TRANSFERENCIA
  ESTORNO
  OUTROS
}

enum StatementStatus {
  UPLOADED
  PROCESSED
  IN_REVIEW
  APPROVED
  EXPORTED
  FAILED
}

enum ExtractionMethod {
  TEXT
  OCR
  HYBRID
}

enum ExtractionRunStatus {
  RUNNING
  DONE
  FAILED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
}

enum IssueStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum IssueType {
  TEMPLATE_NAO_ENCONTRADO
  PARSE_FALHOU
  SALDO_DIVERGENTE
  DATA_FORA_PERIODO
  VALOR_INVALIDO
  OCR_BAIXA_CONFIANCA
  OUTRO
}

enum TransactionAuditAction {
  UPDATE
}

model Statement {
  id             String           @id @default(cuid())
  clientId       String
  entityId       String
  templateId     String?
  periodStart    DateTime?
  periodEnd      DateTime?
  status         StatementStatus  @default(UPLOADED)
  createdByUserId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  client         Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  entity         Entity           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  template       Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  runs           ExtractionRun[]
  issues         ExtractionIssue[]
  dailyBalances  StatementDailyBalance[]
  transactions   Transaction[]

  @@index([clientId, createdAt])
  @@index([entityId, createdAt])
}

model ExtractionRun {
  id           String              @id @default(cuid())
  statementId  String
  method       ExtractionMethod    @default(TEXT)
  status       ExtractionRunStatus @default(RUNNING)
  pagesTotal   Int?
  metrics      Json?
  errorMessage String?
  startedAt    DateTime            @default(now())
  finishedAt   DateTime?

  statement    Statement           @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId, startedAt])
}

model ExtractionIssue {
  id          String        @id @default(cuid())
  statementId String
  runId       String?
  severity    IssueSeverity @default(MEDIUM)
  type        IssueType
  status      IssueStatus   @default(OPEN)
  dedupeKey   String?
  payload     Json?
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?
  resolvedByUserId String?

  statement   Statement     @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId, status, severity])
  @@unique([statementId, dedupeKey])
}

model StatementDailyBalance {
  id          String    @id @default(cuid())
  statementId String
  date        DateTime
  balance     Decimal   @db.Decimal(14, 2)
  createdAt   DateTime  @default(now())

  statement   Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@unique([statementId, date])
  @@index([statementId, date])
}

model Client {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  entities  Entity[]
  templates Template[]
  statements Statement[]
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  role            Role      @default(USER)
  clientId        String
  passwordHash    String?
  twoFactorEnabled Boolean  @default(false)
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  accounts        Account[]
  sessions        Session[]
  transactionAudits TransactionAudit[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Entity {
  id        String   @id @default(cuid())
  nome      String
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  statements Statement[]

  @@index([clientId])
}

model Template {
  id             String   @id @default(cuid())
  nome           String
  identificador  String
  regexData      String
  regexValor     String
  regexDescricao String
  clientId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  statements     Statement[]

  @@index([clientId])
}

model Transaction {
  id          String          @id @default(cuid())
  entityId    String
  statementId String?
  templateId  String?
  data        DateTime
  descricao   String
  categoria   TransactionCategory @default(OUTROS)
  valor       Decimal         @db.Decimal(14, 2)
  tipo        TransactionType
  dedupeHash  String
  createdAt   DateTime        @default(now())

  entity      Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  statement   Statement?      @relation(fields: [statementId], references: [id], onDelete: SetNull)
  template    Template?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  audits      TransactionAudit[]

  @@unique([entityId, dedupeHash])
  @@index([entityId, data])
  @@index([statementId, data])
}

model TransactionAudit {
  id            String                 @id @default(cuid())
  transactionId String
  userId        String
  action        TransactionAuditAction @default(UPDATE)
  before        Json
  after         Json
  createdAt     DateTime               @default(now())

  transaction   Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([transactionId, createdAt])
  @@index([userId, createdAt])
}
